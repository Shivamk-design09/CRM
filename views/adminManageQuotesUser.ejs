<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>User Details</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      background-color: #f5f6fa;
      margin: 0;
      padding: 0;
    }

    .container {
      max-width: 600px;
      margin: 50px auto;
      background: #ffffff;
      padding: 25px 30px;
      border-radius: 10px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

    h2 {
      text-align: center;
      margin-bottom: 20px;
      color: #333;
    }

    .field {
      margin-bottom: 15px;
    }

    .field label {
      display: block;
      font-weight: bold;
      margin-bottom: 5px;
      color: #555;
    }

    .value {
      padding: 10px;
      background: #f9f9f9;
      border-radius: 6px;
      border: 1px solid #eee;
      color: #333;
    }

    textarea {
      width: 100%;
      height: 100px;
      padding: 10px;
      border-radius: 6px;
      border: 1px solid #ddd;
      resize: none;
      font-size: 14px;
    }

    textarea:focus {
      outline: none;
      border-color: #007bff;
    }

    .btn {
      width: 100%;
      padding: 10px;
      background: #007bff;
      color: #fff;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      font-size: 15px;
      margin-top: 10px;
    }

    .btn:hover {
      background: #0056b3;
    }
  </style>
</head>

<body>

<form action="/admin/manageQuotes/<%= user._id %>" method="post">


  <div class="container">
    <h2>User Details</h2>

    <div class="field">
      <label>Name</label>
      <div class="value"><%= user.name %></div>
    </div>

    <div class="field">
      <label>Email</label>
      <div class="value"><%= user.email %></div>
    </div>

    <div class="field">
      <label>Contact</label>
      <div class="value"><%= user.contact %></div>
    </div>

    <div class="field">
      <label>Required Service</label>
      <div class="value"><%= user.webDevlopment %></div>
    </div>

    <div class="field">
      <label>Description</label>
      <div class="value"><%= user.description%></div>
    </div>

    <div class="field">
      <label>Remarks</label>
      <textarea name="remarks" placeholder="Enter remarks..."></textarea>
    </div>

    <button type="submit" class="btn">Submit</button>

  </div>

  </form>

</body>
</html>