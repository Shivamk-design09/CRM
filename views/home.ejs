<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <style>
      * {
        padding: 0;
        margin: 0;
      }

      body {
        overflow: hidden;
      }
      #navbar {
        background-color: rgb(137, 30, 30);
        max-height: 50px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-left: 50px;
        padding-right: 50px;
      }

      #navlink {
        display: flex;
      }
      #navlink a {
        color: white;
        padding-left: 10px;
        text-decoration: none;
      }

      #main {
        background: linear-gradient(red, yellow);
        display: flex;
        flex-direction: column;
        padding-top: 100px;
        padding-bottom: 50px; 
        text-align: center;
        min-height: calc(100vh - 50px);
        color: white;
        align-items: center;
      }

      #main a {
        align-items: center;
        font-size: 20px;
        text-decoration: none;
        background-color: pink;
        padding: 10px;
        border-radius: 5px;
      }

      #main h1{
        padding-bottom: 50px;
      }
    </style>
  </head>
  <body>
    <div>
      <div id="navbar">
        <div>
          <h1>CRM</h1>
        </div>
        <div id="navlink">
          <a href="/register">SIGN UP</a>
          <a href="/login">USER LOGIN</a>
          <a href="/admin">ADMIN</a>
        </div>
      </div>

      <div id="main">
        <h1>Small CRM</h1>
        <h1>Developing using Mongo & Admin</h1>
        <a href="/register">Register</a>
      </div>
    </div>
  </body>
</html>
