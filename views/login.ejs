<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <style>
      * {
        margin: 0;
        padding: 0;
      }
      body {
        background-color: rgb(167, 172, 172);
        font-family: sans-serif;
      }
      #main {
        margin: 0;
        margin-top: 100px;
        padding: 40px;
        display: flex;
        justify-content: center;
      }
      #registerForm form {
        display: flex;
        flex-direction: column;
        width: 300px;
        padding: 20px;
        border-radius: 10px;
      }

      #registerForm input{
         margin-bottom: 15px;
         border: none;
         background-color: white;
         height: 30px;
      }

      #link {
        color: black;
      }

      #submitbtn{
        background-color: aquamarine;
        max-width: 100px;
        border-radius: 3px;
        height: 30px;
        align-items: end;
        
      }
    </style>
  </head>
  <body>
    <div id="main">
      <!-- sign IN  -->
      <div>
        <div>Sign up to CRM</div>
        <div><span><a href="/register">SignUp now</a></span> <span>for a webarch account its free and always be </span></div>
      </div>

      <!-- Register Form  -->
      <div id="registerForm">
        <form action="/login" method="post">
         
          <label for="email">Email</label>
          <input
            type="text"
            name="email"
            id="email"
          />

          <label for="password">Password</label>
          <input
            type="password"
            name="password"
            id="password"
          />

          <button id="submitbtn" type="submit">submit</button>
        </form>
        <a href="/forgotPassowrd">Forget Password</a>
      </div>
    </div>
  </body>
</html>
