<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>

    <style>
        /* Only target table container */
        .table-container {
            margin-left: 260px; /* adjust according to your navbar width */
            padding: 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: white;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        thead {
            background-color: #007bff;
            color: white;
        }

        th, td {
            padding: 12px;
            text-align: left;
        }

        th {
            font-size: 14px;
        }

        td {
            font-size: 13px;
            border-bottom: 1px solid #ddd;
        }

        tbody tr:hover {
            background-color: #f5f5f5;
        }

        button {
            padding: 6px 12px;
            border: none;
            background-color: #28a745;
            border-radius: 5px;
            cursor: pointer;
        }

        button a {
            text-decoration: none;
            color: white;
            font-size: 13px;
        }

        button:hover {
            background-color: #218838;
        }
    </style>
</head>

<body>
   <div class="table-container">
   <table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Email</th>
      <th>Contact</th>
      <th>Service Required</th>
      <th>Action</th>
    </tr>
  </thead>

  <tbody>
    <tr>
      <td><%= user.name %></td>
      <td><%= user.email %></td>
      <td><%= user.contact %></td>
      <td><%= user.webDevlopment %></td>
      <td>
        <button>
          <a href="/user/manageQuote/<%= user._id %>">View</a>
        </button>
      </td>
    </tr>
  </tbody>
</table>
   </div>
</body>
</html>