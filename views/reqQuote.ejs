<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
  </head>
  <body>
    <form action="/profile" method="post">
      <label for="name">Name</label>
      <input type="text" name="name" id="name" value="<%= user.name %>" />

      <label for="email">Email</label>
      <input type="text" name="email" id="email" readonly value="" />

      <label for="company">Confirm Password</label>
      <input type="password" name="company" id="company" />

      <label for="contact">Contact</label>
      <input type="text" name="contact" id="contact" />

      <input type="checkbox" id="webDevelopmen">
      <label for="webDevelopmen">web Developmen</label>

      <button id="submitbtn" type="submit">submit</button>
    </form>
  </body>
</html>
